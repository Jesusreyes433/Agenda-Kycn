NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Contraseña única para que solo el equipo pueda entrar a la app.
# No la pongas con prefijo NEXT_PUBLIC_: debe quedar solo en el servidor.
AGENDA_ACCESS_PASSWORD=elige-una-contrasena

# Contraseña adicional que se pide cada vez que alguien abre el panel
# "Equipo". Debe ser distinta a la de arriba y solo debe conocerla el
# administrador.
AGENDA_ADMIN_PASSWORD=elige-otra-contrasena-distinta
